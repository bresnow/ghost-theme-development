<div class=" lg:w-full md:w-1/2 w-full">
    <div class="parent">
        <div class="card">
            <div
                class="ring-foreground/10 bg-card text-card-foreground gap-4 overflow-hidden rounded-tr-md py-4 text-sm ring-1 px-4 group flex flex-col relative">
                {{#if feature_image}}
                <div class="aspect-video overflow-hidden">
                    <img class="object-cover w-full h-full transform transition duration-500 group-hover:scale-105"
                        srcset="{{img_url feature_image size=" s"}} 300w, {{img_url feature_image size="m" }} 600w,
                        {{img_url feature_image size="l" }} 1000w, {{img_url feature_image size="xl" }} 2000w"
                        sizes="(max-width: 1000px) 400px, 700px" src="{{img_url feature_image size=" m"}}"
                        alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" loading="lazy" />
                </div>
                {{/if}}

                <div class="flex flex-col gap-3">
                    <div class="flex items-center gap-3 text-sm font-medium">
                        {{#primary_tag}}
                        <span
                            class="text-indigo-600 dark:text-indigo-400 px-2.5 py-0.5 bg-indigo-50 dark:bg-indigo-900/30 rounded-none">{{name}}</span>
                        {{/primary_tag}}
                        <span class="text-muted-foreground font-normal">
                            <span class="mx-1.5">&bull;</span>
                            {{reading_time}}
                        </span>
                    </div>
                    {{!-- class="block after:absolute after:inset-0" --}}
                    <a href={{url}}>
                        <button
                            class="text-2xl font-bold leading-tight tracking-tight text-foreground group-hover:text-muted-foreground transition-colors"
                            id="pambutton">
                            {{title}}
                        </button>
                    </a>
                    <p class="text-muted-foreground font-bold line-clamp-2 leading-relaxed">
                        {{excerpt words="50"}}
                    </p>

                    <div class="flex items-center gap-2.5 mt-1">
                        {{#foreach authors}}
                        <span class="text-sm font-medium"> {{#if @first}} Published by {{/if}} {{name}}</span>
                        {{/foreach}}
                    </div>

                </div>


            </div>
            <div class="date-box">

                <span class="month">{{date format="MM"}}</span>
                <span class="date">{{date format="YYYY"}}</span>
            </div>
        </div>
    </div>
</div>
